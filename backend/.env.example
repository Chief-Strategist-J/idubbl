# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=5000
BETTER_AUTH_SECRET=your-secret-key-here
RESEND_API_KEY=your-resend-api-key-here

# ─── Blockchain APIs ──────────────────────────────────────────────────────────
TRONGRID_API_KEY=your-trongrid-api-key
ETHERSCAN_API_KEY=your-etherscan-api-key

# ─── Ethereum RPC (Alchemy) ───────────────────────────────────────────────────
ETH_PROVIDER_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
ALCHEMY_API_KEY=your-alchemy-api-key

# ─── Hot Wallet Private Keys (for automated payouts) ─────────────────────────
# NEVER commit real private keys. Set these in your hosting dashboard only.
TRON_HOT_WALLET_PRIVATE_KEY=
ETH_HOT_WALLET_PRIVATE_KEY=

# ─── Tron Network ─────────────────────────────────────────────────────────────
# Mainnet: https://api.trongrid.io
# Shasta testnet: https://api.shasta.trongrid.io
TRONGRID_BASE_URL=https://api.shasta.trongrid.io
